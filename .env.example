# === Активный провайдер ===
# Переключение модели: измените LLM_PROVIDER и LLM_MODEL
# Провайдеры: anthropic, deepseek, glm, gemini, openai, qwen, yandexgpt, gigachat
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# === LLM API Keys ===
# Заполнить ключи тех провайдеров, которые будут использоваться.
# Для A/B тестирования можно заполнить несколько.
#
# Стоимость за 1 запрос (из расчёта Евроторга):
# GLM-4-Flash     < 0,01 коп.  → LLM_PROVIDER=glm       LLM_MODEL=glm-4-flash
# GLM-4            0,07 коп.   → LLM_PROVIDER=glm       LLM_MODEL=glm-4
# Gemini 2.0 Flash 0,11 коп.   → LLM_PROVIDER=gemini    LLM_MODEL=gemini-2.0-flash
# GPT-4o-mini      0,17 коп.   → LLM_PROVIDER=openai    LLM_MODEL=gpt-4o-mini
# DeepSeek V3      0,30 коп.   → LLM_PROVIDER=deepseek  LLM_MODEL=deepseek-chat
# DeepSeek R1      0,61 коп.   → LLM_PROVIDER=deepseek  LLM_MODEL=deepseek-reasoner
# Claude Haiku 3.5 1,04 коп.   → LLM_PROVIDER=anthropic LLM_MODEL=claude-3-5-haiku-20241022
# Gemini 1.5 Pro   1,38 коп.   → LLM_PROVIDER=gemini    LLM_MODEL=gemini-1.5-pro
# Claude Sonnet 4  3,90 коп.   → LLM_PROVIDER=anthropic LLM_MODEL=claude-sonnet-4-20250514

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_claude_api_key

# DeepSeek V3/R1
DEEPSEEK_API_KEY=your_deepseek_api_key

# GLM-4/GLM-5 (Zhipu AI)
GLM_API_KEY=your_glm_api_key

# Google Gemini
GOOGLE_API_KEY=your_google_api_key

# OpenAI (GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key

# Qwen 2.5 (Alibaba/DashScope) — on-premise кандидат
QWEN_API_KEY=your_qwen_api_key

# YandexGPT
YANDEXGPT_API_KEY=your_yandexgpt_api_key
YANDEXGPT_FOLDER_ID=your_yandex_folder_id

# GigaChat (Сбер)
GIGACHAT_AUTH_KEY=your_gigachat_auth_key

# === Доступ к санкционным API из РБ ===
# Anthropic, OpenAI, Google заблокированы из РБ.
# DeepSeek, GLM, Qwen, YandexGPT, GigaChat — работают напрямую.
#
# ВАРИАНТ 1 (рекомендуемый): API-релей на Render
# Деплоим relay/ на Render (Франкфурт), бот стучится туда.
# Relay проксирует запросы к Claude/OpenAI/Gemini.
RELAY_URL=
RELAY_SECRET=
#
# ВАРИАНТ 2: HTTP/SOCKS5 прокси
# LLM_PROXY_URL=http://user:pass@proxy-server:8080
LLM_PROXY_URL=
#
# Таймаут запросов к LLM (секунды)
LLM_TIMEOUT=60

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# === RAG / Vector DB ===
CHROMA_PERSIST_DIR=./data/chroma

# === Logging ===
LOG_LEVEL=INFO
