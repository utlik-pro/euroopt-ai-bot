# === AI-помощник Евроопт — Конфигурация ===

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# === LLM провайдер ===
# Рекомендуемый для прода: atlas (Atlas Cloud — 300+ моделей, SLA 99.9%)
# Провайдеры: atlas, openrouter, anthropic, deepseek, glm, gemini, openai, qwen, yandexgpt, gigachat
LLM_PROVIDER=atlas
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# === Агрегаторы (рекомендуемый способ — один ключ, все модели) ===

# Atlas Cloud (рекомендуемый) — https://atlascloud.ai
ATLAS_API_KEY=your_atlas_api_key

# OpenRouter (альтернатива) — https://openrouter.ai
OPENROUTER_API_KEY=

# === Прямые API ключи (если не используете агрегатор) ===
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=
GIGACHAT_AUTH_KEY=

# === Доступ из РБ к санкционным API ===
# Anthropic, OpenAI, Google заблокированы из РБ.
# Через агрегаторы (Atlas/OpenRouter) — работает без прокси.
# Через прямые API — нужен прокси или релей.
RELAY_URL=
RELAY_SECRET=
LLM_PROXY_URL=

# === RAG ===
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# === Logging ===
LOG_LEVEL=INFO

# === Access control (MVP whitelist) ===
WHITELIST_ENABLED=true
ALLOWED_USERNAMES=dmitryutlik
ALLOWED_USER_IDS=
